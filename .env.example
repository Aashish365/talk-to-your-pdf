# ── Server ────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATA_DIR=/data/sessions

# ── Session ───────────────────────────────────────
IDLE_TTL_SECONDS=1800          # seconds of inactivity before session expires
MAX_SESSION_AGE_SECONDS=0      # 0 = no hard limit
SWEEPER_INTERVAL_SECONDS=45

# ── Redis ─────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Qdrant ────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=documents

# ── Ollama ────────────────────────────────────────
# Ollama must be running locally on port 11434.
# Pull models first:  ollama pull nomic-embed-text && ollama pull gemma4:e2b
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_GEN_MODEL=gemma4:e2b        # generation model  (change to any model you have)
OLLAMA_EMBED_MODEL=nomic-embed-text # embedding model

# ── Retrieval ─────────────────────────────────────
TOP_K=5           # chunks retrieved per sub-query
CHUNK_OVERLAP=80  # token overlap between adjacent chunks

# ── Upload limits ─────────────────────────────────
MAX_UPLOAD_MB=50
